<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dupliquer une journée</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <%- include('partials/header', { user }) %>

  <main class="page">
    <div class="card" style="margin-top:16px;">
      <h1>Dupliquer une journée</h1>
      <p class="text-muted">Copie les créneaux <strong>libres</strong> d'une date vers une autre.</p>

      <form method="POST" action="/auth/dupliquer-journee">
        <div class="form-grid">
          <div class="form-group">
            <label>Date source</label>
            <input type="date" name="date_source" required>
          </div>

          <div class="form-group">
            <label>Date cible</label>
            <input type="date" name="date_cible" required>
          </div>

          <div class="form-group" style="grid-column: 1 / -1;">
            <label style="display:flex; gap:10px; align-items:center;">
              <input type="checkbox" name="overwrite" value="1">
              Écraser les créneaux libres existants sur la date cible
            </label>
          </div>
        </div>

        <div style="margin-top:14px; display:flex; gap:10px;">
          <button class="btn" type="submit">Dupliquer</button>
          <a class="btn btn-outline" href="/auth/calendar">Retour</a>
        </div>
      </form>
    </div>
  </main>
</body>
</html>