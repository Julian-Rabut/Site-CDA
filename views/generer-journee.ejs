<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Générer des créneaux</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <%- include('partials/header', { user }) %>

  <main class="page">
    <div class="card" style="margin-top:16px;">
      <h1>Générer des créneaux</h1>
      <p class="text-muted">Génère automatiquement des créneaux libres sur une journée.</p>

      <form method="POST" action="/auth/journee/generer" class="form">
        <div class="form-grid">
          <div class="form-group">
            <label>Date</label>
            <input type="date" name="date" required>
          </div>

          <div class="form-group">
            <label>Heure début</label>
            <input type="time" name="startTime" value="08:00" required>
          </div>

          <div class="form-group">
            <label>Heure fin</label>
            <input type="time" name="endTime" value="18:00" required>
          </div>

          <div class="form-group">
            <label>Durée d’un créneau (minutes)</label>
            <input type="number" name="slotMinutes" min="5" step="5" value="60" required>
          </div>

          <div class="form-group">
            <label>Pause entre créneaux (minutes)</label>
            <input type="number" name="breakMinutes" min="0" step="5" value="0">
          </div>
        </div>

        <div style="margin-top:14px; display:flex; gap:10px;">
          <button class="btn" type="submit">Générer</button>
          <a class="btn btn-outline" href="/auth/calendar">Retour calendrier</a>
        </div>
      </form>
    </div>
  </main>
</body>
</html>
