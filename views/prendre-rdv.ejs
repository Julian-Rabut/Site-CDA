<!DOCTYPE html>
<html lang="fr">
<head>
  <%- include('partials/head', { title: 'Prendre rendez-vous', extraCss: [] }) %>
</head>
<body>
  <%- include('partials/header') %>
  <div class="page">
    <div class="header">
      <div>
        <h1>Prendre rendez-vous</h1>
        <% if (praticien) { %>
          <small>Avec <strong><%= praticien.nom %></strong></small>
        <% } %>
      </div>
      <div></div>
    </div>

    <% if (success) { %>
      <div class="alert success">
         Votre rendez-vous est bien réservé. Vous allez recevoir un email de confirmation .
      </div>
    <% } %>

    <% if (profile) { %>
      <div class="card" style="margin-bottom:16px;">
        <h2 style="margin-top:0;"><%= profile.titre || "Votre praticien" %></h2>

        <% if (profile.photo_url) { %>
          <div style="margin:10px 0;">
            <img src="<%= profile.photo_url %>" alt="Photo du praticien"
                style="max-width:140px; border-radius:12px; border:1px solid #e5e5e5;">
          </div>
        <% } %>

        <% if (profile.description) { %>
          <p style="margin:8px 0;"><%= profile.description %></p>
        <% } %>

        <% if (profile.description_seances) { %>
          <div style="margin-top:12px;">
            <strong>Les séances :</strong>
            <pre style="white-space:pre-wrap; margin:6px 0 0;"><%= profile.description_seances %></pre>
          </div>
        <% } %>

        <div style="margin-top:10px;">
          <% if (profile.telephone) { %><div><strong>Téléphone :</strong> <%= profile.telephone %></div><% } %>
          <% if (profile.email_public) { %><div><strong>Email :</strong> <%= profile.email_public %></div><% } %>

          <% if (profile.adresse || profile.ville) { %>
            <div><strong>Adresse :</strong> <%= [profile.adresse, profile.ville].filter(Boolean).join(", ") %></div>
          <% } %>

          <% if (profile.itineraire_url) { %>
            <div><a href="<%= profile.itineraire_url %>" target="_blank" rel="noreferrer">Voir l’itinéraire</a></div>
          <% } %>

          <% if (profile.paiement) { %>
            <div style="margin-top:8px;"><strong>Paiement :</strong> <%= profile.paiement %></div>
          <% } %>

          <% if (profile.tarifs) { %>
            <div style="margin-top:12px;">
              <strong>Tarifs :</strong>
              <pre style="white-space:pre-wrap; margin:6px 0 0;"><%= profile.tarifs %></pre>
            </div>
          <% } %>

          <% if (profile.horaires) { %>
            <div style="margin-top:12px;">
              <strong>Horaires :</strong>
              <pre style="white-space:pre-wrap; margin:6px 0 0;"><%= profile.horaires %></pre>
            </div>
          <% } %>

          <% if (profile.regles) { %>
            <div style="margin-top:8px;"><strong>Infos / règles :</strong><br><%= profile.regles %></div>
          <% } %>
        </div>
      </div>
    <% } %>



    <div class="card">
  <h2>Choisir une séance</h2>

  <% if (typesSeance && typesSeance.length > 0) { %>
    <form method="GET" action="/rdv/<%= praticien.id %>" style="display:flex; gap:10px; align-items:end; flex-wrap:wrap;">
      <div style="flex:1; min-width:240px;">
        <label>Type de séance</label>
        <select name="type" required>
          <option value="">— Choisir un type —</option>
          <% typesSeance.forEach(t => { %>
            <option
              value="<%= t.id %>"
              data-desc="<%= (t.description || '').replace(/\"/g, '&quot;') %>"
              <%= (selectedTypeId && String(selectedTypeId) === String(t.id)) ? 'selected' : '' %>
            >
              <%= t.nom %>
            </option>
          <% }) %>
          </select>
        <div id="typeDesc" style="margin-top:8px; color:#555;"></div>
      </div>

      <button type="submit" class="btn">Voir les créneaux compatibles</button>

      <% if (selectedTypeId) { %>
        <a class="btn btn-outline" href="/rdv/<%= praticien.id %>">Tout afficher</a>
      <% } %>
    </form>
  <% } else { %>
    <p class="text-muted">Aucun type de séance défini par ce praticien.</p>
  <% } %>

  <hr style="margin:16px 0;">

  <h2>Créneaux disponibles</h2>

  <% if (!selectedTypeId) { %>
    <p class="text-muted">Choisis un type de séance pour afficher les créneaux compatibles.</p>
  <% } else if (creneaux.length === 0) { %>
    <p class="text-muted">Aucun créneau compatible pour ce type pour le moment.</p>
  <% } else { %>
    <ul>
      <% creneaux.forEach(c => { %>
        <li>
          <strong><%= c.date_heure_debut.toLocaleString("fr-FR") %></strong>
          → <%= c.display_fin.toLocaleString("fr-FR") %><br>


          <a href="/rdv/reserver/<%= c.id %>?type=<%= selectedTypeId %>" class="btn">
            Réserver ce créneau
          </a>
        </li>
      <% }) %>
    </ul>
  <% } %>
</div>

  <%- include('partials/footer') %>
  <script>
  (function () {
    const sel = document.querySelector('select[name="type"]');
    const box = document.getElementById("typeDesc");
    if (!sel || !box) return;

    function refresh() {
      const opt = sel.options[sel.selectedIndex];
      box.textContent = (opt && opt.dataset.desc) ? opt.dataset.desc : "";
    }

    sel.addEventListener("change", refresh);
    refresh();
  })();
</script>
</body>
</html>
