<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Bloquer une journée</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <%- include('partials/header', { user }) %>

  <main class="page">
    <div class="card" style="margin-top:16px;">
      <h1>Bloquer une journée</h1>
      <p class="text-muted">Empêche toute réservation sur la journée.</p>

      <form method="POST" action="/auth/journee/bloquer" class="form">
        <div class="form-grid">
          <div class="form-group">
            <label>Date</label>
            <input type="date" name="date" required>
          </div>

          <div class="form-group">
            <label>Commentaire (optionnel)</label>
            <input type="text" name="commentaire" maxlength="255" placeholder="Vacances, indisponible, ...">
          </div>
        </div>

        <div style="margin-top:14px; display:flex; gap:10px;">
          <button class="btn" type="submit">Bloquer</button>
          <a class="btn btn-outline" href="/auth/calendar">Retour calendrier</a>
        </div>
      </form>
    </div>
  </main>
</body>
</html>
